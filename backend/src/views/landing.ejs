<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vidra - Universal Video Downloader App & Web Utility</title>
  <meta name="description" content="Download videos from YouTube, TikTok, Instagram, Twitter, and thousands of other platforms. Get the standalone Vidra Android APK for direct installation.">
  <meta name="keywords" content="video downloader, free video download, youtube downloader, tiktok downloader, instagram downloader, download apk">
  <link rel="canonical" href="<%= siteHost %>/">
  
  <!-- Premium Outfit Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  
  <!-- Premium CSS Styles matching App UI Aesthetics -->
  <style>
    :root {
      --app-bg: #EBF0FF;
      --glass-surface: rgba(255, 255, 255, 0.44);
      --glass-border: rgba(255, 255, 255, 0.75);
      --text-primary: #1A1F3A;
      --text-secondary: #6B7494;
      --primary-teal: #00E5A0;
      --primary-coral: #FF6B5A;
      --secondary-accent: #7B8FFF;
      --success: #00C896;
      --error: #FF5252;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Outfit', sans-serif;
    }

    body {
      background-color: var(--app-bg);
      color: var(--text-primary);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow-x: hidden;
    }

    /* Ambient Depth Glow Layer */
    .glow-circle {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
      z-index: 0;
      pointer-events: none;
    }
    .glow-teal {
      top: -100px;
      left: -100px;
      width: 450px;
      height: 450px;
      background-color: var(--primary-teal);
      opacity: 0.14;
    }
    .glow-coral {
      bottom: 15%;
      right: -120px;
      width: 400px;
      height: 400px;
      background-color: var(--primary-coral);
      opacity: 0.12;
    }
    .glow-indigo {
      top: 40%;
      left: 5%;
      width: 300px;
      height: 300px;
      background-color: var(--secondary-accent);
      opacity: 0.10;
    }

    /* Layout Header */
    header {
      width: 100%;
      padding: 24px 8%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 100;
      position: relative;
    }
    .logo-container {
      display: flex;
      align-items: center;
      text-decoration: none;
    }
    .logo-text {
      font-size: 32px;
      font-weight: 900;
      background: linear-gradient(135deg, var(--primary-teal), var(--primary-coral));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -1.5px;
    }
    .nav-links {
      display: flex;
      gap: 32px;
      align-items: center;
    }
    .nav-links a {
      color: var(--text-primary);
      text-decoration: none;
      font-weight: 600;
      font-size: 16px;
      transition: color 0.2s;
    }
    .nav-links a:hover {
      color: var(--primary-coral);
    }
    .apk-dl-btn {
      background: linear-gradient(135deg, var(--primary-teal), var(--primary-coral));
      color: #FFFFFF !important;
      padding: 12px 26px;
      border-radius: 14px;
      font-weight: 700;
      box-shadow: 0 4px 15px rgba(255, 107, 90, 0.25);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .apk-dl-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255, 107, 90, 0.35);
    }

    /* Hamburger Button */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: space-between;
      width: 28px;
      height: 18px;
      background: transparent;
      border: none;
      cursor: pointer;
      z-index: 200;
    }
    .hamburger span {
      width: 100%;
      height: 3px;
      background-color: var(--text-primary);
      border-radius: 3px;
      transition: all 0.3s cubic-bezier(0.075, 0.82, 0.165, 1);
    }
    .hamburger.active span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .hamburger.active span:nth-child(2) {
      opacity: 0;
    }
    .hamburger.active span:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }

    /* Mobile Sliding Menu Overlay */
    .mobile-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      height: 100vh;
      background: rgba(235, 240, 255, 0.96);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      box-shadow: -10px 0 40px rgba(0, 0, 0, 0.08);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 36px;
      z-index: 150;
      transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .mobile-menu.active {
      right: 0;
    }
    .mobile-menu a {
      font-size: 22px;
      font-weight: 700;
      color: var(--text-primary);
      text-decoration: none;
      transition: color 0.2s;
    }
    .mobile-menu a:hover {
      color: var(--primary-coral);
    }
    .mobile-apk-btn {
      background: linear-gradient(135deg, var(--primary-teal), var(--primary-coral));
      color: #FFFFFF !important;
      padding: 14px 32px;
      border-radius: 16px;
      font-weight: 700;
      box-shadow: 0 4px 15px rgba(255, 107, 90, 0.2);
    }

    /* Main Container Centered Layout */
    main {
      flex: 1;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      z-index: 10;
      position: relative;
    }
    
    .hero {
      text-align: center;
      max-width: 850px;
      margin-bottom: 40px;
    }
    .hero h1 {
      font-size: 58px;
      font-weight: 900;
      letter-spacing: -2px;
      margin-bottom: 20px;
      line-height: 1.1;
      background: linear-gradient(135deg, var(--text-primary) 40%, #5263a8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p {
      font-size: 19px;
      color: var(--text-secondary);
      line-height: 1.6;
      font-weight: 400;
    }

    /* Ad Container styles */
    .ad-container {
      width: 100%;
      max-width: 728px;
      min-height: 90px;
      background: var(--glass-surface);
      border: 1.5px solid var(--glass-border);
      border-radius: 16px;
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 24px 0;
      color: var(--text-secondary);
      font-size: 12px;
      font-weight: 600;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    /* Downloader Card container */
    .downloader-card {
      width: 100%;
      max-width: 720px;
      background: var(--glass-surface);
      border: 1.5px solid var(--glass-border);
      border-radius: 32px;
      padding: 40px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.04);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      margin-bottom: 48px;
    }
    .card-title {
      font-size: 24px;
      font-weight: 800;
      margin-bottom: 28px;
      text-align: center;
      color: var(--text-primary);
    }
    .input-row {
      display: flex;
      gap: 12px;
    }
    .url-input {
      flex: 1;
      height: 60px;
      background: rgba(255, 255, 255, 0.7);
      border: 1.5px solid rgba(255, 255, 255, 0.9);
      border-radius: 18px;
      padding: 0 24px;
      font-size: 16px;
      color: var(--text-primary);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .url-input:focus {
      border-color: var(--primary-teal);
      box-shadow: 0 0 0 4px rgba(0, 229, 160, 0.12);
    }
    .submit-btn {
      height: 60px;
      padding: 0 32px;
      background: linear-gradient(135deg, var(--primary-teal), var(--primary-coral));
      color: #FFFFFF;
      font-weight: 700;
      border: none;
      border-radius: 18px;
      cursor: pointer;
      font-size: 17px;
      box-shadow: 0 4px 15px rgba(255, 107, 90, 0.2);
      transition: opacity 0.2s, transform 0.1s, box-shadow 0.2s;
    }
    .submit-btn:hover {
      opacity: 0.95;
      box-shadow: 0 6px 18px rgba(255, 107, 90, 0.3);
    }
    .submit-btn:active {
      transform: scale(0.97);
    }

    /* Result styling */
    .result-container {
      margin-top: 32px;
      display: none;
      border-top: 1.5px solid rgba(26, 31, 58, 0.08);
      padding-top: 28px;
    }
    .video-info {
      display: flex;
      gap: 24px;
      margin-bottom: 28px;
      align-items: center;
    }
    .video-thumb {
      width: 160px;
      aspect-ratio: 16/9;
      border-radius: 14px;
      object-fit: cover;
      border: 1px solid rgba(255, 255, 255, 0.8);
      box-shadow: 0 6px 16px rgba(0,0,0,0.06);
    }
    .video-details {
      flex: 1;
    }
    .video-title {
      font-size: 18px;
      font-weight: 800;
      line-height: 1.3;
      margin-bottom: 10px;
      color: var(--text-primary);
    }
    .video-badge {
      display: inline-block;
      font-size: 12px;
      background: rgba(0, 229, 160, 0.15);
      color: #00936d;
      padding: 6px 12px;
      border-radius: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .formats-list {
      display: flex;
      flex-direction: column;
      gap: 14px;
      max-height: 280px;
      overflow-y: auto;
      padding-right: 4px;
    }
    .formats-list::-webkit-scrollbar {
      width: 6px;
    }
    .formats-list::-webkit-scrollbar-thumb {
      background: rgba(26, 31, 58, 0.12);
      border-radius: 10px;
    }
    .format-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(255, 255, 255, 0.55);
      border: 1.5px solid rgba(255, 255, 255, 0.8);
      padding: 16px 24px;
      border-radius: 16px;
      font-size: 15px;
      transition: background-color 0.2s;
    }
    .format-item:hover {
      background: rgba(255, 255, 255, 0.85);
    }
    .format-left {
      font-weight: 700;
      color: var(--text-primary);
    }
    .format-size {
      color: var(--text-secondary);
      font-size: 13px;
      margin-left: 12px;
      font-weight: 500;
    }
    .dl-icon-btn {
      color: var(--primary-coral);
      text-decoration: none;
      font-weight: 700;
      font-size: 14px;
      padding: 10px 20px;
      border: 1.8px solid var(--primary-coral);
      border-radius: 12px;
      background: transparent;
      transition: all 0.2s;
    }
    .dl-icon-btn:hover {
      background: var(--primary-coral);
      color: #FFFFFF;
      box-shadow: 0 4px 12px rgba(255, 107, 90, 0.2);
    }

    /* Loader styles */
    .loader {
      display: none;
      justify-content: center;
      margin: 24px 0;
    }
    .spinner {
      width: 40px;
      height: 40px;
      border: 4px solid rgba(26, 31, 58, 0.08);
      border-top-color: var(--primary-coral);
      border-radius: 50%;
      animation: spin 0.85s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Flowchart / Step Section */
    .flow-section {
      width: 100%;
      max-width: 1000px;
      padding: 40px 0;
      text-align: center;
    }
    .section-title {
      font-size: 28px;
      font-weight: 800;
      margin-bottom: 32px;
      color: var(--text-primary);
    }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
      margin-top: 16px;
    }
    .step-card {
      background: var(--glass-surface);
      border: 1.5px solid var(--glass-border);
      border-radius: 24px;
      padding: 32px;
      position: relative;
      text-align: left;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.01);
    }
    .step-number {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary-teal), var(--secondary-accent));
      color: #FFFFFF;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    .step-card h3 {
      font-size: 19px;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .step-card p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* Live Stats Section */
    .stats-section {
      width: 100%;
      max-width: 1000px;
      background: linear-gradient(135deg, rgba(123, 143, 255, 0.1), rgba(0, 229, 160, 0.1));
      border: 1.5px solid var(--glass-border);
      border-radius: 28px;
      padding: 36px;
      margin: 40px 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 30px;
      text-align: center;
    }
    .stat-number {
      font-size: 40px;
      font-weight: 900;
      color: var(--text-primary);
      margin-bottom: 6px;
      background: linear-gradient(135deg, var(--text-primary), var(--primary-coral));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .stat-label {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-secondary);
    }

    /* FAQ Section */
    .faq-section {
      width: 100%;
      max-width: 800px;
      padding: 40px 0;
    }
    .faq-grid {
      display: flex;
      flex-direction: column;
      gap: 16px;
      text-align: left;
    }
    .faq-card {
      background: var(--glass-surface);
      border: 1.5px solid var(--glass-border);
      border-radius: 20px;
      padding: 24px;
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .faq-card:hover {
      background: rgba(255, 255, 255, 0.65);
    }
    .faq-question {
      font-size: 17px;
      font-weight: 700;
      color: var(--text-primary);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .faq-answer {
      font-size: 14.5px;
      color: var(--text-secondary);
      line-height: 1.6;
      margin-top: 12px;
      display: none;
      border-top: 1px solid rgba(26, 31, 58, 0.05);
      padding-top: 12px;
    }

    /* Supported Platforms */
    .platforms-section {
      width: 100%;
      max-width: 850px;
      text-align: center;
      padding: 30px 0;
    }
    .platforms-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 24px;
    }
    .platforms-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 16px;
    }
    .platform-badge {
      background: rgba(255, 255, 255, 0.65);
      border: 1.5px solid rgba(255, 255, 255, 0.9);
      padding: 12px 24px;
      border-radius: 14px;
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      transition: transform 0.2s, background-color 0.2s;
    }
    .platform-badge:hover {
      transform: translateY(-2px);
      background-color: #FFFFFF;
    }

    /* Premium Features */
    .features-section {
      width: 100%;
      max-width: 1000px;
      padding: 40px 0 60px 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
    }
    .feature-card {
      background: var(--glass-surface);
      border: 1.5px solid var(--glass-border);
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.01);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transition: transform 0.2s;
    }
    .feature-card:hover {
      transform: translateY(-4px);
    }
    .feature-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: rgba(255, 107, 90, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary-coral);
      font-size: 22px;
      margin-bottom: 20px;
      font-weight: 700;
    }
    .feature-card h3 {
      font-size: 19px;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-primary);
    }
    .feature-card p {
      font-size: 14.5px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* Footer */
    footer {
      width: 100%;
      padding: 48px 8% 36px 8%;
      border-top: 1.5px solid rgba(26, 31, 58, 0.08);
      background: rgba(255,255,255,0.25);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      z-index: 100;
      position: relative;
    }
    .footer-content {
      max-width: 1000px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 32px;
    }
    .footer-left {
      max-width: 450px;
      text-align: left;
    }
    .footer-logo {
      font-size: 22px;
      font-weight: 900;
      margin-bottom: 10px;
      color: var(--text-primary);
    }
    .footer-desc {
      font-size: 13.5px;
      color: var(--text-secondary);
      line-height: 1.5;
    }
    .footer-links {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .footer-links a {
      font-size: 14.5px;
      color: var(--text-primary);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.2s;
    }
    .footer-links a:hover {
      color: var(--primary-coral);
    }
    .copyright {
      width: 100%;
      text-align: center;
      font-size: 13px;
      color: var(--text-secondary);
      margin-top: 36px;
      padding-top: 24px;
      border-top: 1px solid rgba(26, 31, 58, 0.05);
    }

    /* Responsiveness */
    @media (max-width: 900px) {
      header {
        padding: 20px 5%;
      }
      .nav-links {
        display: none;
      }
      .hamburger {
        display: flex;
      }
      .hero h1 {
        font-size: 44px;
      }
      .downloader-card {
        padding: 24px;
      }
    }
    @media (max-width: 600px) {
      .hero h1 {
        font-size: 36px;
      }
      .input-row {
        flex-direction: column;
      }
      .submit-btn {
        width: 100%;
      }
      .video-info {
        flex-direction: column;
        text-align: center;
      }
      .footer-content {
        flex-direction: column;
        text-align: center;
      }
      .footer-left {
        text-align: center;
      }
      .footer-links {
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <!-- Ambient backdrop lights -->
  <div class="glow-circle glow-teal"></div>
  <div class="glow-circle glow-coral"></div>
  <div class="glow-circle glow-indigo"></div>

  <!-- Header Section -->
  <header>
    <a href="/" class="logo-container">
      <span class="logo-text">Vidra</span>
    </a>
    
    <nav class="nav-links">
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
      <a href="/download/apk" class="apk-dl-btn">Download Android APK</a>
    </nav>

    <!-- Hamburger menu trigger -->
    <button class="hamburger" id="hamburgerBtn" onclick="toggleMenu()">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  <!-- Mobile Overlay Panel -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/blog" onclick="toggleMenu()">Blog</a>
    <a href="/contact" onclick="toggleMenu()">Contact</a>
    <a href="/download/apk" class="mobile-apk-btn" onclick="toggleMenu()">Download APK</a>
  </div>

  <!-- Main Portal -->
  <main>
    <section class="hero">
      <h1>Universal Video Downloader</h1>
      <p>Download video files instantly from YouTube, TikTok, Instagram, Twitter, and thousands of other platforms. Use our web client extraction tool below, or download the standalone APK for background downloads directly on your phone.</p>
    </section>

    <!-- Top Ad Banner -->
    <div class="ad-container">
      <span>Google AdSense Slot (Top Banner 728x90)</span>
    </div>

    <!-- Web Downloader Interface -->
    <div class="downloader-card">
      <h2 class="card-title">Extract Quality Formats</h2>
      <div class="input-row">
        <input type="url" id="targetUrl" class="url-input" placeholder="Paste video link here (e.g. YouTube, TikTok, Instagram)..." required>
        <button onclick="extractVideo()" id="extractBtn" class="submit-btn">Extract Video</button>
      </div>

      <div class="loader" id="loader">
        <div class="spinner"></div>
      </div>

      <div id="errorMessage" style="color: var(--error); font-weight: 600; text-align: center; margin-top: 15px; display: none;"></div>

      <!-- Extraction Results -->
      <div class="result-container" id="resultContainer">
        <div class="video-info">
          <img src="" id="resThumb" class="video-thumb" alt="Thumbnail">
          <div class="video-details">
            <h3 id="resTitle" class="video-title">Video Name</h3>
            <span id="resPlatform" class="video-badge">YT-DLP</span>
          </div>
        </div>
        <div class="formats-list" id="resFormats">
          <!-- Dynamically populated format listings -->
        </div>
      </div>
    </div>

    <!-- Supported Platforms Showcase -->
    <section class="platforms-section">
      <h2 class="platforms-title">Supported Video Platforms</h2>
