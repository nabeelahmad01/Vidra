<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vidra - Blog Writer Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --app-bg: #EBF0FF;
      --glass-surface: rgba(255, 255, 255, 0.44);
      --glass-border: rgba(255, 255, 255, 0.75);
      --text-primary: #1A1F3A;
      --text-secondary: #6B7494;
      --primary-teal: #00E5A0;
      --primary-coral: #FF6B5A;
      --secondary-accent: #7B8FFF;
      --error: #FF5252;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
    }

    body {
      background-color: var(--app-bg);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 40px 8%;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
    }
    .logo-text {
      font-size: 28px;
      font-weight: 900;
      background: linear-gradient(135deg, var(--primary-teal), var(--primary-coral));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -1px;
    }
    .back-link {
      color: var(--secondary-accent);
      text-decoration: none;
      font-weight: 600;
    }

    .container {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 40px;
    }

    /* Cards */
    .card {
      background: var(--glass-surface);
      border: 1.5px solid var(--glass-border);
      border-radius: 20px;
      padding: 30px;
      box-shadow: 0 8px 24px rgba(123, 143, 255, 0.05);
      backdrop-filter: blur(10px);
    }
    .card-title {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 20px;
      border-bottom: 1px solid rgba(123, 143, 255, 0.15);
      padding-bottom: 10px;
    }

    /* Form Fields */
    .form-group {
      margin-bottom: 18px;
    }
    .form-label {
      display: block;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--text-secondary);
    }
    .form-input, .form-textarea {
      width: 100%;
      background: rgba(255, 255, 255, 0.6);
      border: 1.5px solid rgba(255, 255, 255, 0.8);
      border-radius: 10px;
      padding: 12px;
      font-size: 15px;
      color: var(--text-primary);
      outline: none;
    }
    .form-input:focus, .form-textarea:focus {
      border-color: var(--primary-teal);
    }
    .form-textarea {
      height: 180px;
      resize: vertical;
    }
    .submit-btn {
      width: 100%;
      height: 48px;
      background: linear-gradient(135deg, var(--primary-teal), var(--primary-coral));
      color: #FFFFFF;
      font-weight: 700;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      font-size: 15px;
      transition: opacity 0.2s;
    }
    .submit-btn:hover {
      opacity: 0.95;
    }

    /* Posts List */
    .post-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(255, 255, 255, 0.3);
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 12px;
    }
    .post-info {
      flex: 1;
      padding-right: 12px;
    }
    .post-name {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .post-meta {
      font-size: 11px;
      color: var(--text-secondary);
    }
    .delete-btn {
      background: none;
      border: 1px solid var(--error);
      color: var(--error);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    .delete-btn:hover {
      background: var(--error);
      color: #FFFFFF;
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo-text">Vidra Admin</div>
    <a href="/blog" class="back-link">&larr; View Blog Portal</a>
  </div>

  <div class="container">
    <!-- Write Card -->
    <div class="card">
      <h2 class="card-title">Publish New SEO Article</h2>
      <form action="/admin/blog" method="POST">
        <div class="form-group">
          <label class="form-label">Article Title</label>
          <input type="text" name="title" class="form-input" placeholder="e.g. How to Stitch HLS Streams Locally" required>
        </div>
        <div class="form-group">
          <label class="form-label">Summary / Description (meta)</label>
          <input type="text" name="summary" class="form-input" placeholder="e.g. Learn how to combine video segment streams..." required>
        </div>
        <div class="form-group">
          <label class="form-label">Cover Image URL</label>
          <input type="url" name="coverImage" class="form-input" placeholder="https://images.unsplash.com/photo-...">
        </div>
        <div class="form-group">
          <label class="form-label">SEO Keywords</label>
          <input type="text" name="keywords" class="form-input" placeholder="e.g. stitch hls, merge m3u8, ffmpeg kit">
        </div>
        <div class="form-group">
          <label class="form-label">Article Body (Supports HTML tags)</label>
          <textarea name="content" class="form-textarea" placeholder="<p>Write your article here...</p>" required></textarea>
        </div>
        <button type="submit" class="submit-btn">Publish Article</button>
      </form>
    </div>

    <!-- Management Card -->
    <div class="card">
      <h2 class="card-title">Manage Published Articles</h2>
      <div class="posts-list">
        <% posts.forEach(post => { %>
          <div class="post-item">
            <div class="post-info">
              <h3 class="post-name"><%= post.title %></h3>
              <span class="post-meta">Slug: <%= post.slug %></span>
            </div>
            <form action="/admin/blog/delete/<%= post.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this article?');">
              <button type="submit" class="delete-btn">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</body>
</html>
