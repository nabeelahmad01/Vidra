  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --app-bg: #EBF0FF;
      --glass-surface: rgba(255, 255, 255, 0.44);
      --glass-border: rgba(255, 255, 255, 0.75);
      --text-primary: #1A1F3A;
      --text-secondary: #6B7494;
      --primary-teal: #00E5A0;
      --primary-coral: #FF6B5A;
    }
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
    }
    body {
      background-color: var(--app-bg);
      color: var(--text-primary);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow-x: hidden;
      padding: 40px 20px;
    }
    .glow-circle {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      z-index: 0;
      pointer-events: none;
    }
    .glow-teal { top: -100px; left: -100px; width: 400px; height: 400px; background-color: var(--primary-teal); opacity: 0.12; }
    .glow-coral { bottom: -100px; right: -100px; width: 380px; height: 380px; background-color: var(--primary-coral); opacity: 0.12; }
    
    .container {
      max-width: 800px;
      margin: 0 auto;
      width: 100%;
      z-index: 1;
      position: relative;
    }
    .back-btn {
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      color: var(--text-primary);
      font-weight: 600;
      font-size: 14px;
      margin-bottom: 24px;
      transition: transform 0.2s;
    }
    .back-btn:hover { transform: translateX(-4px); }
    
    .card {
      background: var(--glass-surface);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      border: 1.5px solid var(--glass-border);
      border-radius: 24px;
      padding: 40px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    }
    h1 {
      font-size: 32px;
      font-weight: 900;
      margin-bottom: 8px;
      background: linear-gradient(135deg, var(--text-primary) 30%, #51428a);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .date {
      color: var(--text-secondary);
      font-size: 14px;
      margin-bottom: 32px;
    }
    h2 {
      font-size: 20px;
      font-weight: 700;
      margin: 28px 0 12px 0;
    }
    p, li {
      font-size: 15px;
      line-height: 1.7;
      color: var(--text-secondary);
      margin-bottom: 16px;
    }
    ul {
      margin-left: 20px;
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <div class="glow-circle glow-teal"></div>
  <div class="glow-circle glow-coral"></div>

  <div class="container">
    <a href="/" class="back-btn">← Back to Home</a>
    
    <div class="card">
